rules_version = '2';

// CM Airlines event check-in rules.
// The app has no authentication, so the scanner reads/writes `checkins`
// unauthenticated. Acceptable for a short, private event — anyone with the
// project config could write. Add Anonymous Auth / App Check for more control.
service cloud.firestore {
  match /databases/{database}/documents {
    match /checkins/{id} {
      // Staff dashboard / live counter can read all check-ins.
      allow read: if true;
      // Register an entry once. Existing docs cannot be overwritten or deleted,
      // so a person's first-in timestamp is preserved.
      allow create: if true;
      allow update, delete: if false;
    }

    // Everything else stays locked.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
